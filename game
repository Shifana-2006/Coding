//collect treasures like coins,rewards.A loop-based game where user actions change health and coins until they win or lose.
import java.util.Scanner;
public class game{
    public static void main(String[] args){
        int health=100;
        int coins=0;
        boolean gameover=false;
        System.out.println("===Welcome to Treasure Hunt===");

        Scanner input = new Scanner(System.in);
        while(true) {
            System.out.print("1.Fight \n ");
            System.out.print("2.Search \n");
            System.out.print("3.Reset \n");
            System.out.print("4.Check status\n");
            System.out.print("5.Quit \n");

            System.out.print("Enter choice: ");
            int choice = input.nextInt();
            if (choice == 1) {
                health -= 20;
                coins += 10;
                System.out.println(" Now Your health is " + health);
                System.out.println(" Now Your coins: " + coins);
            } else if (choice == 2) {
                health -= 10;
                coins += 20;
                System.out.println(" Now Your health is " + health);
                System.out.println(" Now Your coins: " + coins);
            } else if (choice == 3) {
                health += 15;
                coins -= 5;
                System.out.println(" Now Your health is " + health);
                System.out.println(" Now Your coins: " + coins);
            } else if (choice == 4) {
                System.out.println("Current health is " + health);
                System.out.println("Current coins: " + coins);
            } else if (choice == 5) {
                System.out.println("GoodBye");

            } else {
                System.out.println("Invalid choice");
            }
            if (coins>=100) {
                System.out.println("You Win");
                gameover=true;
            } else if(health<0) {
                System.out.println("You Lose");
                gameover=true;
            }
        }
    }
}
